{
	"name": "fork",
	"version": "0.1.5",
	"description": "An opinionated, physics-based toast notification library for Vue 3.",
	"license": "MIT",
	"type": "module",
	"packageManager": "pnpm@9.15.9",
	"repository": {
		"type": "git",
		"url": "https://github.com/Diaz-Cruz/fork.git"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs",
			"default": "./dist/index.mjs"
		},
		"./styles.css": "./dist/styles.css"
	},
	"main": "./dist/index.mjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"files": [
		"dist"
	],
	"scripts": {
		"build": "vue-tsc --noEmit -p tsconfig.build.json && vite build",
		"dev": "vite build --watch",
		"typecheck": "vue-tsc --noEmit -p tsconfig.build.json"
	},
	"peerDependencies": {
		"vue": ">=3.4"
	},
	"dependencies": {
		"@vueuse/core": "^11.3.0",
		"motion-v": "^2.3.0"
	},
	"devDependencies": {
		"@types/node": "^22.10.2",
		"@vitejs/plugin-vue": "^5.2.4",
		"typescript": "^5.6.3",
		"vite": "^6.3.5",
		"vite-plugin-dts": "^4.5.4",
		"vue": "^3.5.13",
		"vue-tsc": "^2.2.10"
	}
}
